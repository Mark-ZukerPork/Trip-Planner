        {
          day: 2,
          date: "2026-03-26",
          activities: []
        },
        {
          day: 3,
          date: "2026-03-27",
          activities: []
        },
        {
          day: 4,
          date: "2026-03-28",
          activities: []
        }
      ],
      budget: { total: 200000, spent: 1500 },
      checklist: [
        { id: 'c1', item: "JR Pass", completed: false },
        { id: 'c2', item: "護照", completed: true }
      ]
    }
  ]
};

// ==========================================
// 2. 核心組件 (UI Components)
// ==========================================

const TypeIcon = ({ type, className }) => {
  const t = type?.toLowerCase() || '';
  if (t === 'food') return <Utensils className={className} />;
  if (t === 'sightseeing') return <Camera className={className} />;
  if (t === 'transport') return <Train className={className} />;
  if (t === 'hotel' || t === 'accommodation') return <Hotel className={className} />;
  if (t === 'shopping') return <ShoppingBag className={className} />;
  return <MapPin className={className} />;
};

const TypeColor = (type) => {
  const t = type?.toLowerCase() || '';
  if (t === 'food') return 'bg-orange-50 text-orange-500';
  if (t === 'sightseeing') return 'bg-blue-50 text-blue-500';
  if (t === 'transport') return 'bg-emerald-50 text-emerald-500';
  if (t === 'hotel' || t === 'accommodation') return 'bg-purple-50 text-purple-500';
  if (t === 'shopping') return 'bg-pink-50 text-pink-500';
  return 'bg-zinc-50 text-zinc-500';
};

// ==========================================
// 3. 主應用程式 (Main App)
// ==========================================

export default function App() {
  const [data, setData] = useState(() => {
    if (typeof window !== 'undefined') {
      const saved = localStorage.getItem(APP_STORAGE_KEY);
      return saved ? JSON.parse(saved) : initialData;
    }
    return initialData;
  });

  const [currentView, setCurrentView] = useState('home'); 
  const [activeTripId, setActiveTripId] = useState(null);
  const [isMenuOpen, setIsMenuOpen] = useState(false);
  const [isCreateModalOpen, setIsCreateModalOpen] = useState(false);

  // 持久化數據
  useEffect(() => {
    localStorage.setItem(APP_STORAGE_KEY, JSON.stringify(data));
  }, [data]);

  const activeTrip = useMemo(() => 
    data.trips.find(t => t.id === activeTripId), 
    [data, activeTripId]
  );

  const handleAddTrip = (newTrip) => {
    setData(prev => ({
      ...prev,
      trips: [newTrip, ...prev.trips]
    }));
    setIsCreateModalOpen(false);
  };

  const handleUpdateTrip = (updatedTrip) => {
    setData(prev => ({
      ...prev,
      trips: prev.trips.map(t => t.id === updatedTrip.id ? updatedTrip : t)
    }));
  };

  const navigateToTrip = (id) => {
    setActiveTripId(id);
    setCurrentView('detail');
    setIsMenuOpen(false);
  };

  return (
    <div className="min-h-screen bg-[#FDFDFD] text-[#2D3436] font-sans">
      
      {/* 頂部 Header */}
      <header className="sticky top-0 z-[60] bg-white/80 backdrop-blur-md border-b border-zinc-100 px-6 py-4">
        <div className="max-w-6xl mx-auto flex items-center justify-between">
          <div className="flex items-center gap-2 cursor-pointer" onClick={() => setCurrentView('home')}>
            <div className="w-8 h-8 bg-[#BC002D] rounded-xl flex items-center justify-center shadow-lg shadow-[#BC002D]/20">
              <Plane className="text-white h-5 w-5" />
            </div>
            <span className="font-black text-xl tracking-tighter italic">V-TRAVEL</span>
          </div>

          <button onClick={() => setIsMenuOpen(!isMenuOpen)} className="p-2 hover:bg-zinc-100 rounded-full transition-colors relative z-[70]">
            {isMenuOpen ? <X /> : <Menu />}
          </button>
        </div>
      </header>

      {/* 選單與彈窗 */}
      <AnimatePresence>
        {isMenuOpen && (
          <motion.div 
            key="menu-backdrop"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black/20 backdrop-blur-sm z-50"
            onClick={() => setIsMenuOpen(false)}
          />
        )}
        {isMenuOpen && (
          <motion.div 
            key="menu-content"
            initial={{ x: '100%' }} animate={{ x: 0 }} exit={{ x: '100%' }}
            className="fixed right-0 top-0 bottom-0 w-[80%] max-w-sm bg-white z-[55] shadow-2xl p-8 pt-24"
          >
            <nav className="space-y-6">
              <p className="text-[10px] font-black text-zinc-300 uppercase tracking-[0.3em] mb-4">主選單</p>
              <button onClick={() => { setCurrentView('home'); setIsMenuOpen(false); }} className="flex items-center gap-4 w-full text-left py-3 border-b border-zinc-50 hover:text-[#BC002D]">
                <Home className="h-5 w-5" /> <span className="font-bold">我的旅程</span>
              </button>
            </nav>
          </motion.div>
        )}
      </AnimatePresence>

      <main>
        {currentView === 'home' ? (
          <HomeDashboard 
            trips={data.trips} 
            onNavigate={navigateToTrip} 
            onCreateOpen={() => setIsCreateModalOpen(true)} 
          />
        ) : (
          <TripDetail 
            trip={activeTrip} 
            onBack={() => setCurrentView('home')} 
            onUpdate={handleUpdateTrip}
          />
        )}
      </main>

      {/* 底部導航欄 */}
      <div className="fixed bottom-6 left-6 right-6 md:hidden z-40">
        <div className="bg-[#2D3436] rounded-[2rem] p-2 flex items-center justify-around shadow-2xl shadow-black/20">
          <button onClick={() => setCurrentView('home')} className={`p-3 rounded-2xl ${currentView === 'home' ? 'bg-white text-[#BC002D]' : 'text-white/40'}`}>
            <Home className="h-6 w-6" />
          </button>
          <button 
            onClick={() => setIsCreateModalOpen(true)}
            className="p-4 bg-[#BC002D] text-white rounded-full -translate-y-6 border-4 border-[#FDFDFD] shadow-xl active:scale-95 transition-transform"
          >
            <Plus className="h-6 w-6" />
          </button>
          <button className="p-3 text-white/40">
            <Briefcase className="h-6 w-6" />
          </button>
        </div>
      </div>

      <AnimatePresence>
        {isCreateModalOpen && (
          <CreateTripModal 
            key="create-modal"
            isOpen={isCreateModalOpen} 
            onClose={() => setIsCreateModalOpen(false)} 
            onSubmit={handleAddTrip} 
          />
        )}
