// --- 詳細行程頁 ---
function TripDetail({ trip, onBack, onUpdate }) {
  const [activeDay, setActiveDay] = useState(1);
  const [detailTab, setDetailTab] = useState('plan');
  const [isActivityModalOpen, setIsActivityModalOpen] = useState(false);
  const [editingActivity, setEditingActivity] = useState(null);

  if (!trip) return null;

  // 核心修復：確保當 activeDay 改變時，對應的日期資訊也隨之更新
  const currentDayData = trip.dailyItinerary.find(d => d.day === activeDay) || { day: activeDay, date: '', activities: [] };

  const handleSaveActivity = (activity) => {
    const updatedDailyItinerary = trip.dailyItinerary.map(day => {
      if (day.day === activeDay) {
        let newActivities;
        if (editingActivity) {
          newActivities = day.activities.map(a => a.id === activity.id ? activity : a);
        } else {
          newActivities = [...day.activities, activity];
        }
        return { ...day, activities: newActivities.sort((a, b) => a.time.localeCompare(b.time)) };
      }
      return day;
    });

    const oldCost = editingActivity ? Number(editingActivity.cost) || 0 : 0;
    const newCost = Number(activity.cost) || 0;

    onUpdate({
      ...trip,
      dailyItinerary: updatedDailyItinerary,
      budget: {
        ...trip.budget,
        spent: trip.budget.spent - oldCost + newCost
      }
    });
    setIsActivityModalOpen(false);
    setEditingActivity(null);
  };

  const handleDeleteActivity = (id) => {
    const activityToDelete = currentDayData.activities.find(a => a.id === id);
    const costToSubtract = activityToDelete ? (Number(activityToDelete.cost) || 0) : 0;

    const updatedDailyItinerary = trip.dailyItinerary.map(day => {
      if (day.day === activeDay) {
        return { ...day, activities: day.activities.filter(a => a.id !== id) };
      }
      return day;
    });

    onUpdate({
      ...trip,
      dailyItinerary: updatedDailyItinerary,
      budget: {
        ...trip.budget,
        spent: Math.max(0, trip.budget.spent - costToSubtract)
      }
    });
  };

  const openInGoogleMaps = (title) => {
    const query = encodeURIComponent(title);
    window.open(`https://www.google.com/maps/search/?api=1&query=${query}`, '_blank');
  };

  return (
    <div className="pb-32">
      <div className="bg-white px-6 border-b border-zinc-50">
        <div className="max-w-6xl mx-auto flex items-center gap-8 overflow-x-auto no-scrollbar py-4">
          <button onClick={onBack} className="p-2 hover:bg-zinc-100 rounded-full shrink-0"><ChevronLeft /></button>
          {[
            { id: 'plan', label: '每日行程', icon: Map },
            { id: 'budget', label: '費用', icon: CreditCard },
            { id: 'tools', label: '清單', icon: Luggage }
          ].map(t => (
            <button key={t.id} onClick={() => setDetailTab(t.id)} className={`flex items-center gap-2 px-4 py-2 rounded-2xl font-bold text-sm shrink-0 ${detailTab === t.id ? 'bg-[#BC002D] text-white' : 'text-zinc-400'}`}>
              <t.icon className="h-4 w-4" /> {t.label}
            </button>
          ))}
        </div>
      </div>

      <div className="max-w-6xl mx-auto px-6 py-10">
        {detailTab === 'plan' && (
          <div className="grid lg:grid-cols-[120px_1fr] gap-10">
            <div className="flex lg:flex-col gap-3 overflow-x-auto no-scrollbar">
              {trip.dailyItinerary.map((dayData) => (
                <button 
                  key={dayData.day} 
                  onClick={() => setActiveDay(dayData.day)} 
                  className={`w-16 h-16 lg:w-full lg:h-auto lg:py-4 rounded-3xl flex flex-col items-center justify-center border shrink-0 transition-all ${activeDay === dayData.day ? 'bg-[#2D3436] text-white shadow-lg' : 'bg-white text-zinc-400 border-zinc-100 hover:border-zinc-300'}`}
                >
                  <span className="text-[10px] font-black">DAY</span>
                  <span className="text-xl font-black">{dayData.day}</span>
                </button>
              ))}
            </div>
            <div className="space-y-6">
              <div className="flex justify-between items-center">
                <div>
                  <h2 className="text-2xl font-black">{currentDayData.date || '未設定日期'}</h2>
                  <p className="text-zinc-400 text-sm font-bold mt-1">第 {activeDay} 天的行程</p>
                </div>
                <div className="text-sm font-bold text-zinc-400 bg-zinc-50 px-4 py-2 rounded-full">
                  {currentDayData.activities.length} 個活動
                </div>
              </div>

              {currentDayData.activities.length > 0 ? (
                currentDayData.activities.map((act) => (
                  <motion.div 
                    initial={{ opacity: 0, y: 10 }}
                    animate={{ opacity: 1, y: 0 }}
                    key={act.id} 
                    className="flex gap-4 items-start bg-white p-6 rounded-[2rem] border border-zinc-50 shadow-sm group hover:shadow-md transition-shadow"
                  >
                    <div className={`p-3 rounded-2xl ${TypeColor(act.type)}`}><TypeIcon type={act.type} className="h-5 w-5" /></div>
                    <div className="flex-1 min-w-0">
                      <div className="flex justify-between text-[10px] font-black text-zinc-300 uppercase mb-1">
                        <span className="flex items-center gap-1"><Clock className="h-3 w-3" /> {act.time}</span>
                        <span>¥{act.cost}</span>
                      </div>
                      <div className="flex items-center gap-2">
                        <h4 className="font-bold text-lg truncate">{act.title}</h4>
                        <button 
                          onClick={() => openInGoogleMaps(act.title)}
                          className="p-1.5 bg-zinc-50 text-zinc-400 hover:text-blue-500 hover:bg-blue-50 rounded-lg transition-colors shrink-0"
                          title="在 Google Maps 中開啟"
                        >
                          <MapPin className="h-3.5 w-3.5" />
                        </button>
                      </div>
                      {act.note && <p className="text-sm text-zinc-400 mt-1 line-clamp-2">{act.note}</p>}
                    </div>
                    <div className="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                      <button 
                        onClick={() => { setEditingActivity(act); setIsActivityModalOpen(true); }}
                        className="p-2 hover:bg-zinc-100 rounded-full text-zinc-400 hover:text-[#2D3436]"
                      >
                        <Edit2 className="h-4 w-4" />
                      </button>
                      <button 
                        onClick={() => handleDeleteActivity(act.id)}
                        className="p-2 hover:bg-zinc-100 rounded-full text-zinc-400 hover:text-red-500"
                      >
                        <Trash2 className="h-4 w-4" />
                      </button>
                    </div>
                  </motion.div>
                ))
              ) : (
                <div className="py-12 text-center bg-zinc-50/50 rounded-[2.5rem] border-2 border-dashed border-zinc-100">
                  <p className="text-zinc-400 font-bold">今日尚無行程</p>
                  <p className="text-zinc-300 text-sm">點擊下方按鈕開始規劃您的完美一天</p>
                </div>
              )}

              <button 
                onClick={() => { setEditingActivity(null); setIsActivityModalOpen(true); }}
                className="w-full py-6 border-2 border-dashed border-zinc-100 rounded-[2rem] text-zinc-300 font-bold hover:bg-zinc-50 hover:border-[#BC002D]/20 hover:text-[#BC002D] transition-all flex items-center justify-center gap-2"
              >
                <Plus className="h-5 w-5" /> 增加活動
              </button>
            </div>
          </div>
        )}
        {detailTab === 'budget' && (
          <div className="bg-white p-10 rounded-[3rem] border border-zinc-100">
             <h2 className="text-2xl font-black mb-6">預算概覽</h2>
             <div className="grid grid-cols-2 gap-6">
                <div className="p-8 bg-zinc-50 rounded-[2rem]">
                  <p className="text-xs font-black text-zinc-300 uppercase mb-2">總預算</p>
                  <p className="text-3xl font-black">¥{trip.budget.total.toLocaleString()}</p>
                </div>
                <div className="p-8 bg-[#BC002D]/5 rounded-[2rem]">
                  <p className="text-xs font-black text-[#BC002D] uppercase mb-2">已支出</p>
                  <p className="text-3xl font-black text-[#BC002D]">¥{trip.budget.spent.toLocaleString()}</p>
                </div>
             </div>
          </div>
        )}
        {detailTab === 'tools' && <div className="p-10 text-center text-zinc-300 font-bold bg-white rounded-[3rem] border border-zinc-100">清單功能即將推出</div>}
      </div>

      <AnimatePresence>
        {isActivityModalOpen && (
          <ActivityModal 
            key="activity-modal"
            initialData={editingActivity}
            onClose={() => { setIsActivityModalOpen(false); setEditingActivity(null); }}
            onSubmit={handleSaveActivity}
          />
        )}
      </AnimatePresence>
    </div>
  );
}

// --- 活動彈窗 ---
function ActivityModal({ initialData, onClose, onSubmit }) {
  const [form, setForm] = useState(initialData || {
    time: '10:00',
    type: 'Sightseeing',
    title: '',
    cost: 0,
    note: ''
  });

  const types = ['Sightseeing', 'Food', 'Transport', 'Hotel', 'Shopping'];

  const handleSubmit = (e) => {
    e.preventDefault();
    if (!form.title) return;
    onSubmit({
      ...form,
      id: form.id || crypto.randomUUID()
    });
  };

  return (
    <div className="fixed inset-0 z-[110] flex items-center justify-center bg-black/40 backdrop-blur-sm p-6">
      <motion.div 
        key="activity-modal-inner"
        initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.9, opacity: 0 }}
        className="bg-white w-full max-w-lg rounded-[3rem] p-10 shadow-2xl overflow-y-auto max-h-[90vh]"
      >
        <div className="flex justify-between items-center mb-8">
          <h2 className="text-2xl font-black">{initialData ? '編輯活動' : '新增活動'}</h2>
          <button onClick={onClose} className="p-2 hover:bg-zinc-100 rounded-full transition-colors"><X /></button>
        </div>

        <form onSubmit={handleSubmit} className="space-y-6">
          <div className="grid grid-cols-2 gap-4">
            <div className="space-y-2">
              <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">時間</label>
              <input 
                type="time" required className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 outline-none font-bold"
                value={form.time} onChange={e => setForm({...form, time: e.target.value})}
              />
            </div>
            <div className="space-y-2">
              <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">類別</label>
              <select 
                className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 outline-none font-bold appearance-none"
                value={form.type} onChange={e => setForm({...form, type: e.target.value})}
              >
                {types.map(t => <option key={t} value={t}>{t}</option>)}
              </select>
            </div>
          </div>

          <div className="space-y-2">
            <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">活動名稱</label>
            <input 
              required className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 focus:ring-2 ring-[#BC002D]/20 outline-none font-bold"
              placeholder="例如：東京鐵塔觀景台"
              value={form.title} onChange={e => setForm({...form, title: e.target.value})}
            />
          </div>

          <div className="space-y-2">
            <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">估計費用 (¥)</label>
            <input 
              type="number" className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 outline-none font-bold"
              value={form.cost} onChange={e => setForm({...form, cost: Number(e.target.value)})}
            />
          </div>

          <div className="space-y-2">
            <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">備註</label>
            <textarea 
              className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 outline-none font-bold min-h-[100px]"
              placeholder="有哪些需要注意的事項？"
              value={form.note} onChange={e => setForm({...form, note: e.target.value})}
            />
          </div>

          <button type="submit" className="w-full bg-[#BC002D] text-white py-5 rounded-[2rem] font-black text-lg shadow-xl shadow-[#BC002D]/20 hover:bg-[#A00026] active:scale-95 transition-all">
            {initialData ? '保存修改' : '確認新增'}
          </button>
        </form>
      </motion.div>
    </div>
  );
}

// --- 新增旅程彈窗 ---
function CreateTripModal({ isOpen, onClose, onSubmit }) {
  const [formData, setFormData] = useState({
    title: '',
    startDate: '',
    endDate: '',
    coverImage: ''
  });

  const handleSubmit = (e) => {
    e.preventDefault();
    if (!formData.title || !formData.startDate || !formData.endDate) return;

    const start = new Date(formData.startDate + "T00:00:00");
    const end = new Date(formData.endDate + "T00:00:00");
    const diffTime = end.getTime() - start.getTime();
    const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24)) + 1;
    const actualDays = diffDays > 0 ? diffDays : 1;

    // 自動生成每日行程結構
    const dailyItinerary = Array.from({ length: actualDays }).map((_, i) => {
      const d = new Date(start);
      d.setDate(start.getDate() + i);
      return {
        day: i + 1,
        date: d.toISOString().split('T')[0],
        activities: []
      };
    });

    const newTrip = {
      id: crypto.randomUUID(),
      title: formData.title,
      startDate: formData.startDate,
      endDate: formData.endDate,
      status: "planning",
      coverImage: formData.coverImage || "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&q=80&w=800",
      dailyItinerary,
      budget: { total: 50000, spent: 0 },
      checklist: []
    };

    onSubmit(newTrip);
    setFormData({ title: '', startDate: '', endDate: '', coverImage: '' });
  };

  return (
    <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm p-6">
      <motion.div 
        key="create-modal-container"
        initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.9, opacity: 0 }}
        className="bg-white w-full max-w-lg rounded-[3rem] p-10 shadow-2xl overflow-y-auto max-h-[90vh]"
      >
        <div className="flex justify-between items-center mb-8">
          <h2 className="text-2xl font-black">開始新旅程</h2>
          <button onClick={onClose} className="p-2 hover:bg-zinc-100 rounded-full transition-colors"><X /></button>
        </div>

        <form onSubmit={handleSubmit} className="space-y-6">
          <div className="space-y-2">
            <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">旅程名稱</label>
            <input 
              required className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 focus:ring-2 ring-[#BC002D]/20 outline-none font-bold"
              placeholder="例如：2026 北海道雪季"
              value={formData.title} onChange={e => setFormData({...formData, title: e.target.value})}
            />
          </div>

          <div className="grid grid-cols-2 gap-4">
            <div className="space-y-2">
              <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">開始日期</label>
              <input 
                type="date" required className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 outline-none font-bold"
                value={formData.startDate} onChange={e => setFormData({...formData, startDate: e.target.value})}
              />
            </div>
            <div className="space-y-2">
              <label className="text-[10px] font-black text-zinc-300 uppercase tracking-widest ml-4">結束日期</label>
              <input 
                type="date" required className="w-full bg-zinc-50 border-none rounded-2xl px-6 py-4 outline-none font-bold"
                value={formData.endDate} onChange={e => setFormData({...formData, endDate: e.target.value})}
              />
            </div>
          </div>

          <button type="submit" className="w-full bg-[#BC002D] text-white py-5 rounded-[2rem] font-black text-lg shadow-xl shadow-[#BC002D]/20 hover:bg-[#A00026] active:scale-95 transition-all">
            建立我的旅程
          </button>
        </form>
      </motion.div>
    </div>
  );
}
