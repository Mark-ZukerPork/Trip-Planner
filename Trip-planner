      dailyItinerary: [
        {
          day: 1,
          date: "2026-03-25",
          activities: [
            { id: 'a1', time: "10:00", type: "Sightseeing", title: "淺草寺", cost: 0, note: "雷門拍照" },
            { id: 'a2', time: "12:30", type: "Food", title: "一蘭拉麵", cost: 1500, note: "排隊約30分鐘" }
          ]
